datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  name     String
  role     String // "Fleet Manager", "Driver", "Safety Officer", "Financial Analyst"
  driver   Driver?
}

model Vehicle {
  id              Int              @id @default(autoincrement())
  make            String
  model           String
  licensePlate    String           @unique
  status          String           @default("Available") // Available, On Trip, In Shop, Retired
  maxCapacityKg   Float
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelExpenseLogs FuelExpenseLog[]
}

model Driver {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id])
  licenseNumber   String   @unique
  licenseExpiry   DateTime
  status          String   @default("Available") // Available, On Trip, Off Duty, Suspended
  suspendedReason String?
  trips           Trip[]
}

model Trip {
  id            Int       @id @default(autoincrement())
  vehicleId     Int
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId      Int
  driver        Driver    @relation(fields: [driverId], references: [id])
  cargoWeightKg Float
  status        String    @default("Draft") // Draft, Dispatched, Completed, Cancelled
  riskScore     Float?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  description String
  date        DateTime @default(now())
  cost        Float
  resolved    Boolean  @default(false)
}

model FuelExpenseLog {
  id           Int      @id @default(autoincrement())
  vehicleId    Int
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  amountLiters Float
  cost         Float
  date         DateTime @default(now())
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  eventType  String // "TripDispatched", "TripBlocked", "MaintenanceLogged", etc.
  entityType String // "Trip" | "Vehicle" | "Driver"
  entityId   Int
  detail     String // human-readable explanation, e.g. rule that fired
  actor      String? // "copilot" | "manual" | userId
  createdAt  DateTime @default(now())
}
